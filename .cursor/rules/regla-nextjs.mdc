}

.titulo {
  font-size: var(--tamaГұo-xl);
  font-weight: 700;
  color: var(--color-texto);
}

/* в”Җв”Җ Tablet (вүҘ 768px) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
@media (min-width: 768px) {
  .contenedor {
    padding: var(--espacio-6);
  }

  .titulo {
    font-size: var(--tamaГұo-2xl);
  }
